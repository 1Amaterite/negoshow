generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Decision {
  APPROVED
  REJECTED
  PENDING
}

enum BulletinStatus {
  PENDING
  PROCESSED
  REQUIRES_MANUAL_REVIEW
}

model AdminUser {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Commodity {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  unit        String  @default("kg")
  description String?
  imageUrl    String?

  retailPrices RetailPrice[]
  vendorChecks VendorCheck[]
}

model Market {
  id   Int    @id @default(autoincrement())
  name String

  retailPrices RetailPrice[]
  vendorChecks VendorCheck[]
}

model RetailPrice {
  id               Int      @id @default(autoincrement())
  commodityId      Int
  marketId         Int
  price            Float
  observedDate     DateTime
  sourceBulletinId Int?
  isProxy          Boolean  @default(false)
  isVerified       Boolean  @default(false)
  createdAt        DateTime @default(now())

  commodity      Commodity       @relation(fields: [commodityId], references: [id])
  market         Market          @relation(fields: [marketId], references: [id])
  sourceBulletin BulletinRecord? @relation(fields: [sourceBulletinId], references: [id])

  @@index([commodityId, observedDate])
}

model VendorCheck {
  id           Int      @id @default(autoincrement())
  commodityId  Int
  marketId     Int?
  checkedPrice Float
  checkedAt    DateTime @default(now())
  isFlagged    Boolean  @default(false)

  commodity           Commodity            @relation(fields: [commodityId], references: [id])
  market              Market?              @relation(fields: [marketId], references: [id])
  validationDecisions ValidationDecision[]

  @@index([commodityId, checkedAt])
}

model BulletinRecord {
  id              Int            @id @default(autoincrement())
  fileUrl         String
  uploadDate      DateTime       @default(now())
  processedStatus BulletinStatus @default(PENDING)

  retailPrices RetailPrice[]
}

model ValidationDecision {
  id            Int      @id @default(autoincrement())
  vendorCheckId Int
  adminDecision Decision
  createdAt     DateTime @default(now())

  vendorCheck VendorCheck @relation(fields: [vendorCheckId], references: [id])
}

model AdminAlert {
  id        Int      @id @default(autoincrement())
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
