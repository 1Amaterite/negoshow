# Database URL (Ask Pete for the connection string)
DATABASE_URL="postgresql://postgres.[project-ref]:[URL-ENCODED-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# Supabase Keys (Ask Pete for the real keys)
NEXT_PUBLIC_SUPABASE_URL="your-supabase-url"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Gemini AI (If used)
GEMINI_API_KEY="your-gemini-api-key"

# NextAuth Configuration (Required for Admin Login to work locally)
# Generate a random secret by running: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"
